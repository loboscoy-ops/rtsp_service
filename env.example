# Скопируйте в .env и при необходимости измените.

# --- Источник данных: excel (файл .xlsx) или sheets (Google Таблица) ---
DATA_SOURCE=excel

# Путь к сохранённому Excel (после загрузки через веб-интерфейс или вручную)
# EXCEL_CAMERAS_PATH=/Users/you/rtsp-camera-service/data/cameras.xlsx

# Пример колонок (первая строка — заголовки):
# № п/п | УИН | Наименование объекта | Адрес объекта | GPS координаты | Ссылка на видеотрансляцию | тип | проект
# В интерфейсе ссылка не показывается — только кнопка «Просмотр потока» (ffplay).

# --- Режим Google Sheets (только если DATA_SOURCE=sheets) ---
# SPREADSHEET_ID=1sYMmVZTjE136vruKJx1hh-gkwax_AtFWHrnO8x2xWkw
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
# GOOGLE_SHEETS_API_KEY=AIza...
# CAMERAS_SHEET_GID=1450282054
# CAMERAS_SHEET=Камеры
# IGNORE_SHEETS=Template,Шаблон,README
# SHEETS_POLL_INTERVAL_SEC=120

# Ping хоста из RTSP URL (секунды). 1800 = 30 минут
PING_INTERVAL_SEC=1800
PING_CONCURRENCY=8

RTSP_FFPROBE_TIMEOUT_US=8000000
RTSP_PROBE_INTERVAL_SEC=300
RTSP_PROBE_CONCURRENCY=4

STATUS_LOG_MAX=500

# CORS_ORIGINS=http://127.0.0.1:3000
