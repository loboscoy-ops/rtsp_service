# Скопируйте в .env и заполните.

# ID из URL таблицы: .../spreadsheets/d/THIS_ID/edit
SPREADSHEET_ID=1sYMmVZTjE136vruKJx1hh-gkwax_AtFWHrnO8x2xWkw

# JSON ключ сервисного аккаунта Google (файл скачивается из Google Cloud Console)
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Лист с таблицей: колонки Проект | Наименование | Тип | URL (rtsp://…).
# gid из URL вкладки (...#gid=1450282054) — надёжнее имени; если задан, имя CAMERAS_SHEET для выбора листа не используется.
CAMERAS_SHEET_GID=1450282054
# Имя листа, если GID не задан. Если оба пусты — режим «каждая вкладка = камера».
CAMERAS_SHEET=Камеры

# Листы с такими именами не считаются камерами (через запятую)
IGNORE_SHEETS=Template,Шаблон,README

# Интервал опроса Google Sheets (секунды)
SHEETS_POLL_INTERVAL_SEC=120

# Ping хоста из RTSP URL (секунды). 1800 = 30 минут
PING_INTERVAL_SEC=1800
PING_CONCURRENCY=8

# ffprobe (резерв, если снова понадобится глубокая проверка потока)
RTSP_FFPROBE_TIMEOUT_US=8000000
RTSP_PROBE_INTERVAL_SEC=300
RTSP_PROBE_CONCURRENCY=4

# Размер журнала ping в памяти
STATUS_LOG_MAX=500

# CORS для UI с другого origin (через запятую). Доступ с телефона в LAN: запускайте
# uvicorn с --host 0.0.0.0 и откройте http://IP:8765 — CORS не нужен.
# CORS_ORIGINS=http://127.0.0.1:3000
